            frame.MouseButton1Click:Connect(function()
                toggled = not toggled
                toggleStates[text] = toggled
                updateToggle()
                callback(toggled)
            end)

            local api = {}
            function api.Set(bool)
                toggled = bool
                toggleStates[text] = toggled
                updateToggle()
                callback(toggled)
            end
            return api
        end

        function Elements:Slider(text, default, min, max, increment, callback)
            callback = callback or function() end
            increment = increment or 1
            default = math.clamp(default or min, min, max)

            local decimals = 0
            local s = tostring(increment)
            local dot = s:find("%.")
            if dot then decimals = #s - dot end

            local currentValue = default

            local frame = Instance.new("Frame")
            frame.BackgroundColor3 = Theme.Surface
            frame.Size = UDim2.new(1, 0, 0, 44)
            frame.Parent = Page
            AddCorner(frame, 6)
            AddStroke(frame, Theme.Border, 1, 0.7)

            local title = Instance.new("TextLabel")
            title.Font = Theme.Font
            title.Text = text
            title.TextColor3 = Theme.Text
            title.TextSize = 13
            title.TextXAlignment = Enum.TextXAlignment.Left
            title.BackgroundTransparency = 1
            title.Position = UDim2.new(0, 12, 0, 0)
            title.Size = UDim2.new(0.5, 0, 0, 22)
            title.Parent = frame

            local valueLabel = Instance.new("TextLabel")
            valueLabel.Font = Theme.FontMedium
            valueLabel.Text = string.format("%." .. decimals .. "f", default)
            valueLabel.TextColor3 = Theme.Accent
            valueLabel.TextSize = 12
            valueLabel.BackgroundTransparency = 1
            valueLabel.AnchorPoint = Vector2.new(1, 0)
            valueLabel.Position = UDim2.new(1, -12, 0, 0)
            valueLabel.Size = UDim2.new(0.2, 0, 0, 22)
            valueLabel.TextXAlignment = Enum.TextXAlignment.Right
            valueLabel.Parent = frame

            local barBG = Instance.new("Frame")
            barBG.BackgroundColor3 = Theme.SurfaceLight
            barBG.Position = UDim2.new(0, 12, 0, 28)
            barBG.Size = UDim2.new(1, -24, 0, 6)
            barBG.Parent = frame
            AddCorner(barBG, 3)

            local barFill = Instance.new("Frame")
            barFill.BackgroundColor3 = Theme.Accent
            barFill.Size = UDim2.fromScale((default - min) / (max - min), 1)
            barFill.Parent = barBG
            AddCorner(barFill, 3)

            -- Glow на fill
            local fillGrad = Instance.new("UIGradient")
            fillGrad.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Theme.AccentDark),
                ColorSequenceKeypoint.new(1, Theme.AccentGlow),
            }
            fillGrad.Parent = barFill

            local isDragging = false

            local function update(x)
                local percent = math.clamp((x - barBG.AbsolutePosition.X) / barBG.AbsoluteSize.X, 0, 1)
                local raw = min + (max - min) * percent
                local snapped = math.round(raw / increment) * increment
                snapped = math.clamp(snapped, min, max)

                if snapped ~= currentValue then
                    currentValue = snapped
                    valueLabel.Text = string.format("%." .. decimals .. "f", snapped)
                    callback(snapped)
                end

                local finalPercent = (snapped - min) / (max - min)
                PlayTween(barFill, {Size = UDim2.fromScale(finalPercent, 1)}, 0.05, Enum.EasingStyle.Quad)
            end

            barBG.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = true
                    update(input.Position.X)
                end
            end)

            RunService.RenderStepped:Connect(function()
                if isDragging then
                    update(UserInputService:GetMouseLocation().X)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = false
                end
            end)
        end

        function Elements:Textbox(text, descOrCallback, callback, options)
            local desc = nil
