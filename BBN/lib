        function Elements:Dropdown(text, list, descOrCallback, callback)
            local desc = nil
            if type(descOrCallback) == "string" then
                desc = descOrCallback
            else
                callback = descOrCallback
            end
            callback = callback or function() end

            local currentList = list
            local isOpen = false
            local height = desc and 44 or 34

            local frame = Instance.new("Frame")
            frame.BackgroundColor3 = Theme.Surface
            frame.Size = UDim2.new(1, 0, 0, height)
            frame.ClipsDescendants = false
            frame.Parent = Page
            AddCorner(frame, 6)
            AddStroke(frame, Theme.Border, 1, 0.7)

            local title = Instance.new("TextLabel")
            title.Font = Theme.Font
            title.Text = text
            title.TextColor3 = Theme.Text
            title.TextSize = 13
            title.TextXAlignment = Enum.TextXAlignment.Left
            title.BackgroundTransparency = 1
            title.Position = UDim2.new(0, 12, 0, 0)
            title.Size = UDim2.new(0.5, 0, 0, desc and 22 or height)
            title.Parent = frame

            if desc then
                local descLabel = Instance.new("TextLabel")
                descLabel.Font = Theme.FontRegular
                descLabel.Text = desc
                descLabel.TextColor3 = Theme.TextMuted
                descLabel.TextSize = 10
                descLabel.TextXAlignment = Enum.TextXAlignment.Left
                descLabel.BackgroundTransparency = 1
                descLabel.Position = UDim2.new(0, 12, 0, 22)
                descLabel.Size = UDim2.new(0.5, 0, 0, 18)
                descLabel.Parent = frame
            end

            local dropBtn = Instance.new("TextButton")
            dropBtn.Font = Theme.FontMedium
            dropBtn.Text = currentList[1] or "Select"
            dropBtn.TextColor3 = Theme.Text
            dropBtn.TextSize = 11
            dropBtn.BackgroundColor3 = Theme.SurfaceLight
            dropBtn.AnchorPoint = Vector2.new(1, 0.5)
            dropBtn.Position = UDim2.new(1, -10, 0.5, 0)
            dropBtn.Size = UDim2.fromOffset(120, 22)
            dropBtn.AutoButtonColor = false
            dropBtn.Parent = frame
            AddCorner(dropBtn, 5)
            AddStroke(dropBtn, Theme.Border, 1, 0.6)

            dropBtn.MouseButton1Click:Connect(function()
                -- Удалить предыдущий dropdown
                local old = ScreenGui:FindFirstChild("DropdownMenu")
                if old then old:Destroy() return end

                local menu = Instance.new("Frame")
                menu.Name = "DropdownMenu"
                menu.BackgroundColor3 = Theme.Surface
                menu.Size = UDim2.fromOffset(120, #currentList * 26 + 8)
                menu.Position = UDim2.fromOffset(
                    dropBtn.AbsolutePosition.X,
                    dropBtn.AbsolutePosition.Y + dropBtn.AbsoluteSize.Y + 4
                )
                menu.ZIndex = 100
                menu.Parent = ScreenGui
                AddCorner(menu, 6)
                AddStroke(menu, Theme.Accent, 1, 0.5)
                AddPadding(menu, 4, 4, 4, 4)
                AddList(menu, 2)

                for _, itemText in ipairs(currentList) do
                    local item = Instance.new("TextButton")
                    item.Font = Theme.FontMedium
                    item.Text = itemText
                    item.TextColor3 = Theme.TextDim
                    item.TextSize = 11
                    item.BackgroundColor3 = Theme.SurfaceLight
                    item.BackgroundTransparency = 1
                    item.Size = UDim2.new(1, 0, 0, 24)
                    item.AutoButtonColor = false
                    item.ZIndex = 101
                    item.Parent = menu
                    AddCorner(item, 4)

                    item.MouseEnter:Connect(function()
                        PlayTween(item, {BackgroundTransparency = 0, TextColor3 = Theme.Text}, 0.15)
                    end)
                    item.MouseLeave:Connect(function()
                        PlayTween(item, {BackgroundTransparency = 1, TextColor3 = Theme.TextDim}, 0.15)
                    end)

                    item.MouseButton1Click:Connect(function()
                        dropBtn.Text = itemText
                        callback(itemText)
                        menu:Destroy()
                    end)
                end

                -- Закрытие при клике вне
                local closeConn
                closeConn = UserInputService.InputBegan:Connect(function(input, gpe)
                    if gpe then return end
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        task.wait(0.05)
                        if menu.Parent then menu:Destroy() end
                        closeConn:Disconnect()
                    end
                end)
            end)

            local api = {}
            function api.UpdateList(newList)
                currentList = newList
            end
            return api
        end

        return Elements
    end

    function WindowHandler:Exit()
        PlayTween(Main, {Size = UDim2.fromOffset(520, 0), BackgroundTransparency = 1}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.delay(0.35, function()
            ScreenGui:Destroy()
        end)
    end

    return WindowHandler
end

return Library
