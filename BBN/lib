            textBox.ClearTextOnFocus = false
            textBox.Parent = frame
            AddCorner(textBox, 5)
            AddStroke(textBox, Theme.Border, 1, 0.6)

            textBox.Focused:Connect(function()
                PlayTween(textBox, {BackgroundColor3 = Theme.SurfaceHover}, 0.2)
                PlayTween(textBox:FindFirstChildOfClass("UIStroke"), {Color = Theme.Accent}, 0.2)
            end)

            textBox.FocusLost:Connect(function()
                PlayTween(textBox, {BackgroundColor3 = Theme.SurfaceLight}, 0.2)
                PlayTween(textBox:FindFirstChildOfClass("UIStroke"), {Color = Theme.Border}, 0.2)
                callback(textBox.Text)
                if options.clear ~= false then
                    textBox.Text = ""
                end
            end)
