        AddPadding(Page, 8, 8, 8, 8)
        AddList(Page, 5)

        tabs[myIndex] = {button = TabButton, page = Page, indicator = tabIndicator}

        local function activate()
            if activeTab == myIndex then return end
            activeTab = myIndex

            for i, t in pairs(tabs) do
                if i == myIndex then
                    PlayTween(t.button, {TextColor3 = Theme.Text, BackgroundTransparency = 0.5}, 0.3)
                    PlayTween(t.indicator, {BackgroundTransparency = 0}, 0.3)
                    t.page.Visible = true
                    -- Fade in
                    t.page.BackgroundTransparency = 1
                    for _, child in ipairs(t.page:GetChildren()) do
                        if child:IsA("GuiObject") then
                            child.Position = child.Position + UDim2.fromOffset(0, 15)
                        end
                    end
                    PlayTween(t.page, {BackgroundTransparency = 0}, 0.2)
                    for _, child in ipairs(t.page:GetChildren()) do
                        if child:IsA("GuiObject") then
                            PlayTween(child, {Position = child.Position - UDim2.fromOffset(0, 15)}, 0.3, Enum.EasingStyle.Back)
                        end
                    end
                else
                    PlayTween(t.button, {TextColor3 = Theme.TextDim, BackgroundTransparency = 1}, 0.3)
                    PlayTween(t.indicator, {BackgroundTransparency = 1}, 0.3)
                    t.page.Visible = false
                end
            end
        end

        TabButton.MouseButton1Click:Connect(activate)

        -- Первый таб активен по умолчанию
