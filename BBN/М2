                            teleported = true
                            root.Anchored = true
                            root.CFrame = part.CFrame
                            task.delay(1.5, function() root.Anchored = false end)
                            task.delay(10, function() teleported = false end)
                        end
                    end
                end
            end
        end)
    end
    notify("Auto Escape", state and "Enabled" or "Disabled")
end)

