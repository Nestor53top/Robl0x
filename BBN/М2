vistab:Label("ESP & Visual Features")

local esp = {survivors = {}, killers = {}, generators = {}}

local function newHL(obj, color)
    if not obj then return end
    local h = Instance.new("Highlight")
    h.FillColor = color
    h.FillTransparency = 0.5
    h.OutlineColor = color
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee = obj
    h.Parent = obj
    return h
end

local function espAdd(tbl, obj, color)
    if obj and not tbl[obj] then tbl[obj] = newHL(obj, color) end
end

local function espRemove(tbl, obj)
    if tbl[obj] then tbl[obj]:Destroy(); tbl[obj] = nil end
end

local function espClear(tbl)
    for obj, h in pairs(tbl) do if h then h:Destroy() end; tbl[obj] = nil end
end

vistab:Toggle("Survivor ESP", "Highlight all alive survivors.", function(state)
    local alive = workspace.PLAYERS.ALIVE
    if esp.sAdd then esp.sAdd:Disconnect() end
    if esp.sRem then esp.sRem:Disconnect() end
    espClear(esp.survivors)

    if state then
        for _, v in ipairs(alive:GetChildren()) do
            if v:IsA("Model") then espAdd(esp.survivors, v, Color3.fromRGB(80, 180, 255)) end
        end
        esp.sAdd = alive.ChildAdded:Connect(function(v)
            if v:IsA("Model") then espAdd(esp.survivors, v, Color3.fromRGB(80, 180, 255)) end
        end)
        esp.sRem = alive.ChildRemoved:Connect(function(v) espRemove(esp.survivors, v) end)
    end
    notify("Survivor ESP", state and "Enabled" or "Disabled")
end)

vistab:Toggle("Killer ESP", "Highlight the killer in red.", function(state)
    local killers = workspace.PLAYERS.KILLER
    if esp.kAdd then esp.kAdd:Disconnect() end
    if esp.kRem then esp.kRem:Disconnect() end
    espClear(esp.killers)

    if state then
        for _, v in ipairs(killers:GetChildren()) do
            if v:IsA("Model") then espAdd(esp.killers, v, Color3.fromRGB(255, 80, 80)) end
        end
        esp.kAdd = killers.ChildAdded:Connect(function(v)
            if v:IsA("Model") then espAdd(esp.killers, v, Color3.fromRGB(255, 80, 80)) end
        end)
        esp.kRem = killers.ChildRemoved:Connect(function(v) espRemove(esp.killers, v) end)
    end
    notify("Killer ESP", state and "Enabled" or "Disabled")
end)

vistab:Toggle("Generator ESP", "Highlight all generators.", function(state)
    if esp.gAdd then esp.gAdd:Disconnect() end
    if esp.gRem then esp.gRem:Disconnect() end
    espClear(esp.generators)

    if state then
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v.Name == "Generator" then
                espAdd(esp.generators, v, Color3.fromRGB(0, 255, 100))
            end
        end
        esp.gAdd = workspace.DescendantAdded:Connect(function(v)
            if v:IsA("Model") and v.Name == "Generator" then
                espAdd(esp.generators, v, Color3.fromRGB(0, 255, 100))
            end
        end)
        esp.gRem = workspace.DescendantRemoving:Connect(function(v) espRemove(esp.generators, v) end)
    end
    notify("Generator ESP", state and "Enabled" or "Disabled")
end)

